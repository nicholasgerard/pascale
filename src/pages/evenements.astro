---
import Layout from '../components/Layout.astro';
---

<Layout
	title="Événements — Agissons Ensemble avec Pascale Richard"
	description="Calendrier des événements et rencontres de la liste Agissons Ensemble pour les élections consulaires 2026."
	path="/evenements"
	currentPage="evenements"
>
	<!-- ═══ PAGE HEADER ═══ -->
	<section class="page-header">
		<div class="container">
			<p class="election-label" data-i18n data-i18n-fr="Élections consulaires 2026" data-i18n-en="Consular Elections 2026">Élections consulaires 2026</p>
			<h1 data-i18n data-i18n-fr="Événements" data-i18n-en="Events">Événements</h1>
			<p class="page-subtitle" data-i18n data-i18n-fr="Rencontrons-nous" data-i18n-en="Let's meet">Rencontrons-nous</p>
		</div>
	</section>

	<!-- ═══ EVENTS ═══ -->
	<section class="events-section">
		<div class="container narrow">

			<!-- Event 1: March 10 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">10</span>
					<span class="event-month" data-i18n data-i18n-fr="MARS" data-i18n-en="MAR">MARS</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Mardi 10 mars à 18h30" data-i18n-en="Tuesday, March 10 at 6:30 PM">Mardi 10 mars à 18h30</p>
					<h3 data-i18n data-i18n-fr="Rencontre avec Aurore Bergé" data-i18n-en="Meeting with Aurore Bergé">Rencontre avec Aurore Bergé</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Ministre de l'Égalité entre les femmes et les hommes et de la lutte contre les discriminations, modérée par Aissata Fernandez Taranto et Yvan Bedouet."
						data-i18n-en="Minister for Equality between Women and Men and the Fight against Discrimination, moderated by Aissata Fernandez Taranto and Yvan Bedouet.">
						Ministre de l'Égalité entre les femmes et les hommes et de la lutte contre les discriminations, modérée par Aissata Fernandez Taranto et Yvan Bedouet.
					</p>
					<p class="event-location">126 West 87th Street, New York, NY 10024</p>
					<a href="https://www.eventbrite.com/e/rencontre-electorale-avec-madame-la-ministre-aurore-berge-tickets-1984322946349" target="_blank" rel="noopener noreferrer" class="btn btn-sm" data-i18n data-i18n-fr="S'inscrire sur Eventbrite" data-i18n-en="Register on Eventbrite">
						S'inscrire sur Eventbrite
					</a>
				</div>
			</div>

			<!-- Event 2: March 19 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">19</span>
					<span class="event-month" data-i18n data-i18n-fr="MARS" data-i18n-en="MAR">MARS</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Jeudi 19 mars à 18h30" data-i18n-en="Thursday, March 19 at 6:30 PM">Jeudi 19 mars à 18h30</p>
					<h3 data-i18n data-i18n-fr="Rencontre avec Samantha Cazebonne" data-i18n-en="Meeting with Samantha Cazebonne">Rencontre avec Samantha Cazebonne</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Sénatrice des Français de l'Étranger — Éducation en français à l'étranger avec Isabelle Bonneau et Guillaume Haeringer, modéré par Pascale Richard."
						data-i18n-en="Senator for French Citizens Abroad — French education abroad with Isabelle Bonneau and Guillaume Haeringer, moderated by Pascale Richard.">
						Sénatrice des Français de l'Étranger — Éducation en français à l'étranger avec Isabelle Bonneau et Guillaume Haeringer, modéré par Pascale Richard.
					</p>
					<p class="event-location">Aux Merveilleux de Fred, 1001 6th Avenue, New York, NY 10018</p>
					<a href="https://www.eventbrite.com/e/rencontre-avec-la-senatrice-samantha-cazebonne-tickets-1984351431549" target="_blank" rel="noopener noreferrer" class="btn btn-sm" data-i18n data-i18n-fr="S'inscrire sur Eventbrite" data-i18n-en="Register on Eventbrite">
						S'inscrire sur Eventbrite
					</a>
				</div>
			</div>

		</div>
	</section>

	<!-- ═══ STAY CONNECTED ═══ -->
	<section class="stay-connected">
		<div class="container narrow">
			<div class="section-header">
				<span class="section-rule" aria-hidden="true"></span>
				<p class="section-label" data-i18n data-i18n-fr="Restons en contact" data-i18n-en="Stay connected">Restons en contact</p>
				<span class="section-rule" aria-hidden="true"></span>
			</div>
			<h2 class="section-title" data-i18n data-i18n-fr="Ne manquez aucune actualité" data-i18n-en="Don't miss any updates">Ne manquez aucune actualité</h2>
			<div class="connect-grid">
				<a href="https://www.instagram.com/agissonsensemble2026" target="_blank" rel="noopener noreferrer" class="connect-card" aria-label="Instagram @agissonsensemble2026">
					<span class="connect-icon" aria-hidden="true">@</span>
					<h3>Instagram</h3>
					<p>@agissonsensemble2026</p>
				</a>
				<a href="mailto:contact@agissonsensemble2026.com" class="connect-card" aria-label="Email contact@agissonsensemble2026.com">
					<span class="connect-icon" aria-hidden="true">✉</span>
					<h3>Email</h3>
					<p data-i18n data-i18n-fr="Contactez-nous" data-i18n-en="Contact us">Contactez-nous</p>
				</a>
			</div>
		</div>
	</section>

	<!-- ═══ CTA ═══ -->
	<section class="cta-section">
		<div class="container">
			<h2 data-i18n data-i18n-fr="Découvrez notre programme" data-i18n-en="Discover our platform">Découvrez notre programme</h2>
			<p data-i18n data-i18n-fr="Éducation, Social, Santé — trois priorités pour notre communauté." data-i18n-en="Education, Social, Health — three priorities for our community.">Éducation, Social, Santé — trois priorités pour notre communauté.</p>
			<div class="cta-buttons">
				<a href="/programme" class="btn btn-primary" data-i18n data-i18n-fr="Notre programme" data-i18n-en="Our platform">Notre programme</a>
				<a href="/la-liste" class="btn btn-ghost-light" data-i18n data-i18n-fr="Découvrir la liste" data-i18n-en="Meet the team">Découvrir la liste</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* ─── PAGE HEADER ─── */
	.page-header {
		background: var(--navy-deep);
		color: var(--white);
		text-align: center;
		padding: 4rem 2rem 3.5rem;
	}

	.election-label {
		text-transform: uppercase;
		letter-spacing: 0.25em;
		font-size: 0.6875rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.4);
		margin-bottom: 1rem;
	}

	.page-header h1 {
		font-size: clamp(2.25rem, 5vw, 3.5rem);
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	.page-subtitle {
		font-size: 1.0625rem;
		color: rgba(255, 255, 255, 0.6);
		font-style: italic;
	}

	/* ─── EVENTS SECTION ─── */
	.events-section {
		padding: 4rem 0;
		background: var(--off-white);
	}

	.event-card {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 1.5rem;
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 2rem;
		margin-bottom: 1.5rem;
		position: relative;
	}

	.event-card::before {
		content: '';
		position: absolute;
		top: -1px;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, var(--navy), var(--red));
	}

	.event-date {
		text-align: center;
		padding-top: 0.25rem;
	}

	.event-day {
		display: block;
		font-size: 2.25rem;
		font-weight: 700;
		color: var(--navy);
		line-height: 1;
	}

	.event-month {
		display: block;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--red);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-top: 0.25rem;
	}

	.event-time {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--red);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.375rem;
	}

	.event-info h3 {
		font-size: 1.25rem;
		color: var(--navy);
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.event-desc {
		font-size: 0.9375rem;
		line-height: 1.7;
		color: var(--muted);
		margin-bottom: 0.5rem;
	}

	.event-location {
		font-size: 0.875rem;
		color: var(--muted);
		margin-bottom: 1.25rem;
	}

	.event-location::before {
		content: '📍 ';
	}

	.btn-sm {
		display: inline-block;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.625rem 1.25rem;
		background: var(--navy);
		color: var(--white);
		text-decoration: none;
		transition: background 0.2s ease;
	}

	.btn-sm:hover {
		background: var(--red);
	}

	/* ─── STAY CONNECTED ─── */
	.stay-connected {
		padding: 4rem 0;
		background: var(--surface);
	}

	.connect-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		max-width: 500px;
		margin: 0 auto;
	}

	.connect-card {
		background: var(--off-white);
		border: 1px solid var(--border);
		padding: 2rem 1.5rem;
		text-align: center;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.connect-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
	}

	.connect-icon {
		display: block;
		font-size: 1.5rem;
		margin-bottom: 0.75rem;
		color: var(--red);
	}

	.connect-card h3 {
		font-size: 1rem;
		color: var(--navy);
		font-weight: 700;
		margin-bottom: 0.25rem;
	}

	.connect-card p {
		font-size: 0.875rem;
		color: var(--muted);
	}

	/* ─── CTA ─── */
	.cta-section {
		background: var(--navy-deep);
		color: var(--white);
		text-align: center;
		padding: 4rem 0;
	}

	.cta-section h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		margin-bottom: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.cta-section p {
		color: rgba(255, 255, 255, 0.55);
		font-size: 1rem;
		font-style: italic;
		margin-bottom: 2rem;
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* ─── RESPONSIVE ─── */
	@media (max-width: 640px) {
		.event-card {
			grid-template-columns: 1fr;
			gap: 1rem;
			padding: 1.5rem;
		}

		.event-date {
			display: flex;
			align-items: baseline;
			gap: 0.5rem;
			text-align: left;
		}

		.event-day {
			font-size: 1.75rem;
		}

		.event-month {
			margin-top: 0;
		}

		.connect-grid {
			grid-template-columns: 1fr;
		}

		.page-header {
			padding: 3rem 1.5rem 2.5rem;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}
	}
</style>
