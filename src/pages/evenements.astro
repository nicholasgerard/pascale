---
import Layout from '../components/Layout.astro';
import EventGallery from '../components/EventGallery.astro';
---

<Layout
	title="Événements — Agissons Ensemble avec Pascale Richard"
	description="Calendrier des événements et rencontres de la liste Agissons Ensemble pour les élections consulaires 2026."
	path="/evenements"
	currentPage="evenements"
>
	<!-- ═══ PAGE HEADER ═══ -->
	<section class="page-header">
		<div class="container">
			<p class="election-label" data-i18n data-i18n-fr="Élections consulaires 2026" data-i18n-en="Consular Elections 2026">Élections consulaires 2026</p>
			<h1 data-i18n data-i18n-fr="Événements" data-i18n-en="Events">Événements</h1>
			<p class="page-subtitle" data-i18n data-i18n-fr="Rencontrons-nous" data-i18n-en="Let's meet">Rencontrons-nous</p>
		</div>
	</section>

	<!-- ═══ EVENTS ═══ -->
	<section class="events-section">
		<div class="container narrow">

			<!-- April 18 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">18</span>
					<span class="event-month" data-i18n data-i18n-fr="AVR" data-i18n-en="APR">AVR</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Samedi 18 avril à 17h00" data-i18n-en="Saturday, April 18 at 5:00 PM">Samedi 18 avril à 17h00</p>
					<h3 data-i18n data-i18n-fr="Rencontre — Élections consulaires" data-i18n-en="Meeting — Consular Elections">Rencontre — Élections consulaires</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Réunion d'information sur les élections consulaires avec Pascale Richard, tête de la liste Agissons Ensemble."
						data-i18n-en="Information meeting about the consular elections with Pascale Richard, head of the Agissons Ensemble slate.">
						Réunion d'information sur les élections consulaires avec Pascale Richard, tête de la liste Agissons Ensemble.
					</p>
					<p class="event-location">c/o Marie Jose Hunter, 17 Wainscott Stone Road, Wainscott, NY 11975</p>
					<img src="/assets/images/events/apr_18.jpg" alt="Réunion d'information sur les élections consulaires avec Pascale Richard" class="event-poster" width="1080" height="1080" loading="lazy" />
					<a href="https://www.eventbrite.com/e/1986643530278" target="_blank" rel="noopener noreferrer" class="btn btn-sm" data-i18n data-i18n-fr="S'inscrire sur Eventbrite" data-i18n-en="Register on Eventbrite">
						S'inscrire sur Eventbrite
					</a>
				</div>
			</div>

			<!-- April 13 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">13</span>
					<span class="event-month" data-i18n data-i18n-fr="AVR" data-i18n-en="APR">AVR</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Lundi 13 avril à 18h00" data-i18n-en="Monday, April 13 at 6:00 PM">Lundi 13 avril à 18h00</p>
					<h3 data-i18n data-i18n-fr="Rencontre avec R. Lescure, ministre, et C. Weissberg, notre député" data-i18n-en="Meeting with R. Lescure, Minister, and C. Weissberg, our MP">Rencontre avec R. Lescure, ministre, et C. Weissberg, notre député</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Rencontre avec Roland Lescure, ministre, et Christophe Weissberg, notre député."
						data-i18n-en="Meeting with Roland Lescure, Minister, and Christophe Weissberg, our MP.">
						Rencontre avec Roland Lescure, ministre, et Christophe Weissberg, notre député.
					</p>
					<p class="event-location">743 East 6th Street, New York, NY 10009</p>
					<span class="event-passed" data-i18n data-i18n-fr="Événement passé" data-i18n-en="Past event">Événement passé</span>

					<EventGallery slug="apr_13" count={6} altPrefix="Rencontre avec R. Lescure et C. Weissberg" />
				</div>
			</div>

			<!-- April 11 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">11</span>
					<span class="event-month" data-i18n data-i18n-fr="AVR" data-i18n-en="APR">AVR</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Samedi 11 avril à 11h00" data-i18n-en="Saturday, April 11 at 11:00 AM">Samedi 11 avril à 11h00</p>
					<h3 data-i18n data-i18n-fr="Rencontre avec Pascale Richard" data-i18n-en="Meeting with Pascale Richard">Rencontre avec Pascale Richard</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Conseillère des Français de l'Étranger — Rencontrez Pascale Richard et les membres de sa liste au festival francophone de Princeton."
						data-i18n-en="Councillor for French Citizens Abroad — Meet Pascale Richard and members of her slate at the Princeton francophone festival.">
						Conseillère des Français de l'Étranger — Rencontrez Pascale Richard et les membres de sa liste au festival francophone de Princeton.
					</p>
					<p class="event-location">Princeton Public Library, 65 Witherspoon Street, Princeton, NJ 08542</p>
					<span class="event-passed" data-i18n data-i18n-fr="Événement passé" data-i18n-en="Past event">Événement passé</span>

					<EventGallery slug="apr_11" count={11} altPrefix="Rencontre avec Pascale Richard à Princeton" />
				</div>
			</div>

			<!-- March 19 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">19</span>
					<span class="event-month" data-i18n data-i18n-fr="MARS" data-i18n-en="MAR">MARS</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Jeudi 19 mars à 18h30" data-i18n-en="Thursday, March 19 at 6:30 PM">Jeudi 19 mars à 18h30</p>
					<h3 data-i18n data-i18n-fr="Rencontre avec Samantha Cazebonne" data-i18n-en="Meeting with Samantha Cazebonne">Rencontre avec Samantha Cazebonne</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Sénatrice des Français de l'Étranger — Éducation en français à l'étranger avec Isabelle Bonneau et Guillaume Haeringer, modérée par Pascale Richard."
						data-i18n-en="Senator for French Citizens Abroad — French education abroad with Isabelle Bonneau and Guillaume Haeringer, moderated by Pascale Richard.">
						Sénatrice des Français de l'Étranger — Éducation en français à l'étranger avec Isabelle Bonneau et Guillaume Haeringer, modérée par Pascale Richard.
					</p>
					<p class="event-location">Aux Merveilleux de Fred, 1001 6th Avenue, New York, NY 10018</p>
					<span class="event-passed" data-i18n data-i18n-fr="Événement passé" data-i18n-en="Past event">Événement passé</span>
				</div>
			</div>

			<!-- March 10 -->
			<div class="event-card">
				<div class="event-date">
					<span class="event-day">10</span>
					<span class="event-month" data-i18n data-i18n-fr="MARS" data-i18n-en="MAR">MARS</span>
				</div>
				<div class="event-info">
					<p class="event-time" data-i18n data-i18n-fr="Mardi 10 mars à 20h30" data-i18n-en="Tuesday, March 10 at 8:30 PM">Mardi 10 mars à 20h30</p>
					<h3 data-i18n data-i18n-fr="Rencontre avec Aurore Bergé" data-i18n-en="Meeting with Aurore Bergé">Rencontre avec Aurore Bergé</h3>
					<p class="event-desc" data-i18n
						data-i18n-fr="Ministre de l'Égalité entre les femmes et les hommes et de la lutte contre les discriminations, modérée par Aissata Fernandez Taranco et Yvan Bedouet."
						data-i18n-en="Minister for Equality between Women and Men and the Fight against Discrimination, moderated by Aissata Fernandez Taranco and Yvan Bedouet.">
						Ministre de l'Égalité entre les femmes et les hommes et de la lutte contre les discriminations, modérée par Aissata Fernandez Taranco et Yvan Bedouet.
					</p>
					<p class="event-location">126 West 87th Street, New York, NY 10024</p>
					<span class="event-passed" data-i18n data-i18n-fr="Événement passé" data-i18n-en="Past event">Événement passé</span>

					<EventGallery slug="mar_10" count={3} altPrefix="Rencontre avec Aurore Bergé" />
				</div>
			</div>

			<!-- Lightbox -->
			<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
				<button class="lightbox-close" aria-label="Fermer">&times;</button>
				<button class="lightbox-prev" aria-label="Previous">&#8249;</button>
				<img class="lightbox-img" src="" alt="" />
				<button class="lightbox-next" aria-label="Next">&#8250;</button>
			</div>

		</div>
	</section>

	<!-- ═══ STAY CONNECTED ═══ -->
	<section class="stay-connected">
		<div class="container narrow">
			<div class="section-header">
				<span class="section-rule" aria-hidden="true"></span>
				<p class="section-label" data-i18n data-i18n-fr="Restons en contact" data-i18n-en="Stay connected">Restons en contact</p>
				<span class="section-rule" aria-hidden="true"></span>
			</div>
			<h2 class="section-title" data-i18n data-i18n-fr="Ne manquez aucune actualité" data-i18n-en="Don't miss any updates">Ne manquez aucune actualité</h2>
			<div class="connect-grid">
				<a href="https://www.instagram.com/agissonsensemble2026" target="_blank" rel="noopener noreferrer" class="connect-card" aria-label="Instagram @agissonsensemble2026">
					<span class="connect-icon" aria-hidden="true">@</span>
					<h3>Instagram</h3>
					<p>@agissonsensemble2026</p>
				</a>
				<a href="mailto:contact@agissonsensemble2026.com" class="connect-card" aria-label="Email contact@agissonsensemble2026.com">
					<span class="connect-icon" aria-hidden="true">✉</span>
					<h3>Email</h3>
					<p data-i18n data-i18n-fr="Contactez-nous" data-i18n-en="Contact us">Contactez-nous</p>
				</a>
			</div>
		</div>
	</section>

	<!-- ═══ CTA ═══ -->
	<section class="cta-section">
		<div class="container">
			<h2 data-i18n data-i18n-fr="Découvrez notre programme" data-i18n-en="Discover our platform">Découvrez notre programme</h2>
			<p data-i18n data-i18n-fr="Éducation, Social, Santé — trois priorités pour notre communauté." data-i18n-en="Education, Social, Health — three priorities for our community.">Éducation, Social, Santé — trois priorités pour notre communauté.</p>
			<div class="cta-buttons">
				<a href="/programme" class="btn btn-primary" data-i18n data-i18n-fr="Notre programme" data-i18n-en="Our platform">Notre programme</a>
				<a href="/la-liste" class="btn btn-ghost-light" data-i18n data-i18n-fr="Découvrir la liste" data-i18n-en="Meet the team">Découvrir la liste</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* ─── PAGE HEADER ─── */
	.page-header {
		background: var(--navy-deep);
		color: var(--white);
		text-align: center;
		padding: 4rem 2rem 3.5rem;
	}

	.election-label {
		text-transform: uppercase;
		letter-spacing: 0.25em;
		font-size: 0.6875rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.4);
		margin-bottom: 1rem;
	}

	.page-header h1 {
		font-size: clamp(2.25rem, 5vw, 3.5rem);
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	.page-subtitle {
		font-size: 1.0625rem;
		color: rgba(255, 255, 255, 0.6);
		font-style: italic;
	}

	/* ─── EVENTS SECTION ─── */
	.events-section {
		padding: 4rem 0;
		background: var(--off-white);
	}

	.event-card {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 1.5rem;
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 2rem;
		margin-bottom: 1.5rem;
	}

	.event-date {
		text-align: center;
		padding-top: 0.25rem;
	}

	.event-day {
		display: block;
		font-size: 2.25rem;
		font-weight: 700;
		color: var(--navy);
		line-height: 1;
	}

	.event-month {
		display: block;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--red);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-top: 0.25rem;
	}

	.event-time {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--red);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.375rem;
	}

	.event-info h3 {
		font-size: 1.25rem;
		color: var(--navy);
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.event-desc {
		font-size: 0.9375rem;
		line-height: 1.7;
		color: var(--muted);
		margin-bottom: 0.5rem;
	}

	.event-location {
		font-size: 0.875rem;
		color: var(--muted);
		margin-bottom: 1.25rem;
	}

	.event-location::before {
		content: '📍 ';
	}

	.btn-sm {
		display: inline-block;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.625rem 1.25rem;
		background: var(--navy);
		color: var(--white);
		text-decoration: none;
		transition: background 0.2s ease;
	}

	.btn-sm:hover {
		background: var(--red);
	}

	.event-poster {
		width: 100%;
		max-width: 480px;
		height: auto;
		border: 1px solid var(--border);
		margin-bottom: 1.25rem;
	}

	.event-passed {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.5rem 1rem;
		background: var(--off-white);
		color: var(--muted);
		border: 1px solid var(--border);
	}

	/* ─── LIGHTBOX ─── */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: rgba(0, 0, 0, 0.9);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
	}

	.lightbox[hidden] {
		display: none;
	}

	.lightbox-close {
		all: unset;
		position: absolute;
		top: 1rem;
		right: 1.5rem;
		font-size: 2rem;
		color: white;
		cursor: pointer;
		line-height: 1;
		padding: 0.5rem;
		z-index: 1;
		transition: opacity 0.2s ease;
	}

	.lightbox-close:hover {
		opacity: 0.7;
	}

	.lightbox-prev,
	.lightbox-next {
		all: unset;
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		font-size: 3rem;
		color: white;
		cursor: pointer;
		padding: 1rem;
		line-height: 1;
		transition: opacity 0.2s ease;
		user-select: none;
	}

	.lightbox-prev { left: 0.5rem; }
	.lightbox-next { right: 0.5rem; }

	.lightbox-prev:hover,
	.lightbox-next:hover {
		opacity: 0.7;
	}

	.lightbox-img {
		max-width: calc(100% - 6rem);
		max-height: 90vh;
		object-fit: contain;
	}

	/* ─── STAY CONNECTED ─── */
	.stay-connected {
		padding: 4rem 0;
		background: var(--surface);
	}

	.connect-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		max-width: 500px;
		margin: 0 auto;
	}

	.connect-card {
		background: var(--off-white);
		border: 1px solid var(--border);
		padding: 2rem 1.5rem;
		text-align: center;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.connect-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
	}

	.connect-icon {
		display: block;
		font-size: 1.5rem;
		margin-bottom: 0.75rem;
		color: var(--red);
	}

	.connect-card h3 {
		font-size: 1rem;
		color: var(--navy);
		font-weight: 700;
		margin-bottom: 0.25rem;
	}

	.connect-card p {
		font-size: 0.875rem;
		color: var(--muted);
	}

	/* ─── CTA ─── */
	.cta-section {
		background: var(--navy-deep);
		color: var(--white);
		text-align: center;
		padding: 4rem 0;
	}

	.cta-section h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		margin-bottom: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.cta-section p {
		color: rgba(255, 255, 255, 0.55);
		font-size: 1rem;
		font-style: italic;
		margin-bottom: 2rem;
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* ─── RESPONSIVE ─── */
	@media (max-width: 640px) {
		.event-card {
			grid-template-columns: 1fr;
			gap: 1rem;
			padding: 1.5rem;
		}

		.event-date {
			display: flex;
			align-items: baseline;
			gap: 0.5rem;
			text-align: left;
		}

		.event-day {
			font-size: 1.75rem;
		}

		.event-month {
			margin-top: 0;
		}

		.connect-grid {
			grid-template-columns: 1fr;
		}

		.page-header {
			padding: 3rem 1.5rem 2.5rem;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}
	}
</style>

<script>
	function initGallery() {
		const lightbox = document.getElementById('lightbox');
		if (!lightbox) return;
		const lightboxImg = lightbox.querySelector('.lightbox-img') as HTMLImageElement;
		const closeBtn = lightbox.querySelector('.lightbox-close');
		const prevBtn = lightbox.querySelector('.lightbox-prev');
		const nextBtn = lightbox.querySelector('.lightbox-next');
		let currentGroup: Element[] = [];
		let currentIndex = 0;

		function showPhoto(index: number) {
			const btn = currentGroup[index];
			if (!btn) return;
			currentIndex = index;
			lightboxImg.src = btn.getAttribute('data-full') || '';
			lightboxImg.alt = btn.querySelector('img')?.alt || '';
		}

		document.querySelectorAll('.event-gallery').forEach((gallery) => {
			const groupThumbs = Array.from(gallery.querySelectorAll('.gallery-thumb'));
			groupThumbs.forEach((btn, i) => {
				btn.addEventListener('click', () => {
					currentGroup = groupThumbs;
					showPhoto(i);
					lightbox.hidden = false;
					document.body.style.overflow = 'hidden';
				});
			});
		});

		function closeLightbox() {
			lightbox.hidden = true;
			lightboxImg.src = '';
			document.body.style.overflow = '';
		}

		prevBtn?.addEventListener('click', () => {
			if (!currentGroup.length) return;
			showPhoto((currentIndex - 1 + currentGroup.length) % currentGroup.length);
		});

		nextBtn?.addEventListener('click', () => {
			if (!currentGroup.length) return;
			showPhoto((currentIndex + 1) % currentGroup.length);
		});

		closeBtn?.addEventListener('click', closeLightbox);
		lightbox.addEventListener('click', (e) => {
			if (e.target === lightbox) closeLightbox();
		});
		document.addEventListener('keydown', (e) => {
			if (lightbox.hidden || !currentGroup.length) return;
			if (e.key === 'Escape') closeLightbox();
			if (e.key === 'ArrowLeft') showPhoto((currentIndex - 1 + currentGroup.length) % currentGroup.length);
			if (e.key === 'ArrowRight') showPhoto((currentIndex + 1) % currentGroup.length);
		});
	}
	document.addEventListener('DOMContentLoaded', initGallery);
</script>
